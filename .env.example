# Frontend
VITE_API_BASE_URL=
VITE_API_TOKEN=
VITE_DEV_API_BASE_URL=http://127.0.0.1:8787

# Worker API
API_TOKEN=replace-with-a-long-random-token
APP_ORIGIN=http://localhost:5173
EMAIL_PROVIDER=smtp

# SMTP provider
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USERNAME=sender@example.com
SMTP_PASSWORD=replace-with-smtp-password
SMTP_FROM_EMAIL=sender@example.com
SMTP_FROM_NAME=Mail Reminder

# Cloud Mail provider
CLOUDMAIL_BASE_URL=https://mail.example.com
CLOUDMAIL_TOKEN=replace-with-login-token
CLOUDMAIL_ACCOUNT_ID=1
CLOUDMAIL_FROM_NAME=Mail Reminder
