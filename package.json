{
  "name": "mail-reminder",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:frontend\"",
    "dev:api": "wrangler dev --local --port 8787",
    "dev:frontend": "vite --host 0.0.0.0",
    "build": "vite build && tsc --noEmit",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "deploy": "npm run build && wrangler deploy",
    "deploy:worker": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply mail_reminder --local",
    "db:migrate:remote": "wrangler d1 migrations apply mail_reminder --remote"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.2",
    "clsx": "^2.1.1",
    "hono": "^4.8.12",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260710.1",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.2",
    "vite": "^6.0.3",
    "vitest": "^4.1.10",
    "wrangler": "^4.24.3"
  }
}
